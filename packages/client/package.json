{
  "name": "@geomesh/convex-sse",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/geomesh/convex-sse.git",
    "directory": "packages/client"
  },
  "type": "module",
  "description": "Drop-in WebSocket transport for Convex clients behind WebSocket-blocking firewalls (SSE-over-HTTP).",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build:js": "bun build ./src/index.ts --target browser --format esm --outdir dist",
    "build:types": "dts-bundle-generator -o dist/index.d.ts src/index.ts",
    "build": "bun run build:js && bun run build:types",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1"
  }
}
